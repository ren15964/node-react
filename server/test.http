@baseUrl = http://localhost:3000

### 登录后，把返回的 token 复制到下面的变量里
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{
  "username": "admin",
  "password": "123456"
}

### 将这里替换成上一步返回的 token
@token = Bearer replace_me

### 获取当前登录用户信息
GET {{baseUrl}}/api/user/profile
Authorization: {{token}}

### 获取分类列表
GET {{baseUrl}}/api/categories

### 获取标签列表
GET {{baseUrl}}/api/tags

### 创建已发布文章，并指定分类和标签
POST {{baseUrl}}/api/articles
Content-Type: application/json
Authorization: {{token}}

{
  "title": "一篇带标签的已发布文章",
  "content": "这篇文章会对所有用户可见，并且带有分类和标签。",
  "status": "published",
  "categoryId": 2,
  "tagIds": [2, 4]
}

### 创建草稿文章，并指定分类和标签
POST {{baseUrl}}/api/articles
Content-Type: application/json
Authorization: {{token}}

{
  "title": "一篇带标签的草稿文章",
  "content": "这篇文章只有作者本人可见，适合测试标签和草稿组合。",
  "status": "draft",
  "categoryId": 3,
  "tagIds": [1, 2, 4]
}

### 游客查看文章列表
GET {{baseUrl}}/api/articles

### 登录后查看文章列表，作者可以看到自己的草稿
GET {{baseUrl}}/api/articles?status=all
Authorization: {{token}}

### 按分类筛选文章列表
GET {{baseUrl}}/api/articles?status=all&categoryId=2
Authorization: {{token}}

### 按标签筛选文章列表
GET {{baseUrl}}/api/articles?status=all&tagId=2
Authorization: {{token}}

### 查看文章详情
GET {{baseUrl}}/api/articles/1

### 更新文章状态、分类和标签
PUT {{baseUrl}}/api/articles/1
Content-Type: application/json
Authorization: {{token}}

{
  "title": "更新后的文章标题",
  "content": "更新后的文章内容",
  "status": "published",
  "categoryId": 1,
  "tagIds": [1, 3]
}
